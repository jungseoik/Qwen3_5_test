# ============================================================================
# Qwen3.5 vLLM 튜토리얼 - 환경변수 템플릿
#
# 사용법:
#   cp .env.example .env       # 본 파일을 복사 후 환경에 맞게 수정
#   docker compose up -d       # compose가 .env 자동 로드
#
# 본 파일의 변수는 docker-compose.yml의 ${VAR:-default} 보간 + 컨테이너 내부
# shell expansion으로 vLLM CLI 인자에 매핑된다.
# ============================================================================


# ============================================================================
# [1] vLLM 베이스 이미지 (GPU 아키텍처별로 다름!)
# ============================================================================
#   Blackwell  (B200, RTX 5090, RTX PRO 6000)      → vllm/vllm-openai:cu130-nightly
#   Hopper     (H100, H200)                         → vllm/vllm-openai:latest
#   Ampere     (A100, A10, RTX 30/40 시리즈)        → vllm/vllm-openai:latest
# 잘못된 태그를 쓰면 CUDA 호환성 오류로 컨테이너가 즉시 종료된다.
VLLM_IMAGE=vllm/vllm-openai:cu130-nightly


# ============================================================================
# [2] 모델 / 토큰
# ============================================================================
# HuggingFace 모델 path. 아래 값 중 하나로 바꾸고 docker compose down && up 하면 교체된다.
# 모두 캐시(~/.cache/huggingface)에 받아둔 Qwen3.5 계열. weight VRAM은 fp16 기준 추정치.
#   Qwen/Qwen3.5-0.8B                 ~1.6GB   (현재 기본값)
#   Qwen/Qwen3.5-2B                   ~4GB
#   Qwen/Qwen3.5-4B                   ~8GB
#   cyankiwi/Qwen3.5-4B-AWQ-4bit      ~3GB     (AWQ 4bit 양자화)
#   Qwen/Qwen3.5-9B                   ~18GB
#   QuantTrio/Qwen3.5-9B-AWQ          ~7GB     (AWQ 4bit 양자화)
#   Qwen/Qwen3.5-27B                  ~54GB
#   Qwen/Qwen3.5-35B-A3B              ~70GB    (MoE)
# 큰 모델로 VRAM이 부족하면 GPU_MEMORY_UTILIZATION 상향, 단일 GPU에 안 들어가면
# GPU_COUNT + TENSOR_PARALLEL_SIZE 를 GPU 수만큼 상향.
VLLM_MODEL=Qwen/Qwen3.5-0.8B

# HuggingFace 액세스 토큰.
#   - gated 모델(예: meta-llama/*) / private 모델 사용 시 필수
#   - 공개 모델(Qwen 등)만 쓰면 빈 값 유지
# 발급: https://huggingface.co/settings/tokens 에서 'read' 권한 토큰 생성
# 형식: hf_xxxxxxxxxxxxxxxxxxxx (따옴표 X, 공백 X)
HF_TOKEN=


# ============================================================================
# [3] 병렬화
# ============================================================================
# Tensor Parallel — 한 모델을 여러 GPU에 weight 단위로 분산. 0.8B는 1로 충분.
TENSOR_PARALLEL_SIZE=1
# Data Parallel — 동일 모델을 여러 GPU에 복제하여 throughput N배.
DATA_PARALLEL_SIZE=1


# ============================================================================
# [4] VRAM 상한 / KV 캐시 / dtype
# ============================================================================
# vLLM이 점유할 VRAM 상한 (0.0~1.0). 모델 weight + KV 캐시 + activation 합계.
# 너무 낮으면 동시 처리량 급락, 너무 높으면 다른 프로세스와 OOM 충돌.
# 96GB GPU + 0.8B 모델이면 0.2(=약 19GB)로 넉넉하다.
# [원래 기본값] 0.2  /  [대량 서빙 변경] 0.85 - 96GB를 더 쓰도록 풀어 동시 처리량 확보
GPU_MEMORY_UTILIZATION=0.85

# KV 캐시 메모리 크기 (예: 1G, 4G). 빈 값이면 vLLM 자동 계산.
KV_CACHE_MEMORY_BYTES=1G

# 모델 weight / KV 캐시 dtype. auto = 모델 config 따름 (대부분 bf16/fp16).
DTYPE=auto


# ============================================================================
# [5] 컨텍스트 / 동시 처리 한계
# ============================================================================
# 한 요청의 input+output+이미지 토큰 상한.
MAX_MODEL_LEN=4096
# 동시 디코딩 시퀀스 상한. 초과 요청은 큐잉.
# [원래 기본값] 64  /  [대량 서빙 변경] 128 - 초당 128장 폭주 버퍼 확보 (출력 1토큰이라 부담 적음)
MAX_NUM_SEQS=128
# 한 step의 prefill+decode 토큰 상한.
# [원래 기본값] 8192  /  [대량 서빙 변경] 32768 - 1080p(2,600토큰) 기준 한 스텝 ~3장→~12장
MAX_NUM_BATCHED_TOKENS=32768
# 프롬프트당 미디어 입력 상한.
LIMIT_MM_PER_PROMPT={"image":1}


# ============================================================================
# [6] 처리량 최적화 / 모델 옵션
# ============================================================================
# 동일 prefix 반복 요청 캐시 → latency 감소.
ENABLE_PREFIX_CACHING=true
# reasoning 모델용 파서 (예: qwen3). 비-reasoning 모델은 빈 값.
REASONING_PARSER=
# 재현성을 위한 시드.
VLLM_SEED=0


# ============================================================================
# [7] 자유 입력 - 대량 이미지 VQA 서빙 튜닝
# ============================================================================
# ▶ 먼저 직관 하나만 잡고 가자.
#   vLLM이 요청 하나를 처리하는 시간 = (1) + (2) 이다.
#     (1) PREFILL = "이미지를 읽고 질문을 이해하는" 시간  → 입력이 길수록 김
#     (2) DECODE  = "답을 한 글자씩 써내려가는" 시간       → 출력이 길수록 김
#   우리는 답이 yes/no 1토큰뿐 → (2) DECODE는 사실상 0.
#   => 성능은 오직 "이미지를 얼마나 빨리·많이 동시에 읽느냐(PREFILL)"로 결정된다.
#
# ▶ 이미지 1장이 먹는 토큰 수 (대략):
#     720p  (1280x720)  ≈ 1,200 토큰
#     1080p (1920x1080) ≈ 2,600 토큰
#   한 요청 = 이미지 토큰 + 프롬프트 수십 토큰 + 출력 1토큰.
#
# ▶ "64개 요청이 초당 2번(=초당 128장) 들어온다" 같은 폭주 상황이면
#   아래 [처방]을 1순위부터 올린다. 전부 VRAM과 맞바꾸는 것이라
#   96GB처럼 여유가 크면 공격적으로 올려도 된다.
#
# ---------------------------------------------------------------------------
# [처방 1순위] "한 번에 읽는 양" + "동시에 든 요청 수" 늘리기  ← 효과 가장 큼
#   (이 둘은 위쪽 [5] 섹션의 정식 변수다. 여기 EXTRA가 아니라 거기서 바꾼다.)
# ---------------------------------------------------------------------------
#   [5] MAX_NUM_BATCHED_TOKENS (현재 8192)
#       = "한 스텝에 읽을 수 있는 총 토큰 수".
#       8192면 1080p(2,600토큰) 기준 한 스텝에 겨우 ~3장.
#       32768로 올리면 한 스텝에 ~12장 → 이미지 처리량이 그만큼 뜀.
#       (+) throughput 직접 증가   (-) 스텝당 activation VRAM 증가
#
#   [5] MAX_NUM_SEQS (현재 64)
#       = "동시에 들고 있을 수 있는 요청 수".
#       64개가 한꺼번에 몰리고 폭주 버퍼까지 보려면 128~256 권장.
#       출력이 1토큰이라 요청이 금방 빠져나가 크게 잡아도 부담이 적다.
#       ※ MAX_NUM_BATCHED_TOKENS가 작으면 이것만 올려도 소용없다 (둘은 한 쌍).
#
# ---------------------------------------------------------------------------
# [처방 2순위] VRAM을 더 쓰도록 풀어주기 (1순위를 더 크게 잡기 위한 토대)
#   (역시 위쪽 [4]/[5] 정식 변수다.)
# ---------------------------------------------------------------------------
#   [4] GPU_MEMORY_UTILIZATION (현재 0.2 = 96GB 중 ~19GB만 사용 중)
#       여유 있으면 0.8~0.9로 올려 공간을 넓힌다 → 위 두 값을 더 키울 수 있다.
#   [5] MAX_MODEL_LEN (현재 4096)
#       한 요청의 (이미지+프롬프트+출력) 토큰이 이 값을 넘으면 거부된다.
#       1080p(2,600)+프롬프트면 4096으로 충분. 더 큰 이미지를 쓸 거면 상향.
#
# ---------------------------------------------------------------------------
# [처방 3순위] 동시 prefill 겹치기  (총량보다 "공정성" 효과가 큼)
#   (아래는 정식 변수가 없어 EXTRA_VLLM_ARGS 줄에 직접 붙여야 적용된다.)
# ---------------------------------------------------------------------------
#   --max-num-partial-prefills N    (기본 1)
#       긴 이미지 여러 장을 동시에 조금씩 읽게 함 → 한 장이 줄을 막는 것 방지.
#   --max-long-partial-prefills N   (기본 1)
#       그중 "긴 프롬프트(=이미지)"를 동시에 몇 개까지 읽을지.
#   --long-prefill-token-threshold N (기본 0=끔)
#       이 토큰 이상이면 "긴 요청"으로 분류. 우리는 거의 다 이미지라 효과 제한적.
#   ※ 이 셋은 raw 처리량보다 "짧은 요청이 굶지 않게" 하는 쪽 효과가 크다.
#
# ---------------------------------------------------------------------------
# [항상 켜두는 것]  ← 아래 EXTRA_VLLM_ARGS 기본값에 이미 들어가 있음
# ---------------------------------------------------------------------------
#   --mm-processor-cache-gb 0       서로 다른 이미지라 캐시 무의미 → 꺼서 VRAM 절약
#   --performance-mode throughput   지연보다 "총 처리량" 우선 모드
#
# ---------------------------------------------------------------------------
# [그 외 비상용]  (메모리 압박 시에만)
# ---------------------------------------------------------------------------
#   --kv-cache-dtype fp8   KV 캐시 절반 → 동시 수용 2배. 단 출력 1토큰이라 KV가
#                          작은 우리 워크로드엔 이득 적음. 현재 auto 유지.
#   --enforce-eager        CUDA graph 끔 → VRAM 절약 + cold start 대폭 단축
#                          (모델 로딩 9~20분 → 1~2분). graph 는 주로 decode용이라
#                          1토큰 출력 워크로드에선 throughput 손실 거의 없음.
#                          → 현재 기본 적용 (아래 EXTRA_VLLM_ARGS 줄 참고).
#
# 예: EXTRA_VLLM_ARGS=--mm-processor-cache-gb 0 --performance-mode throughput --max-num-partial-prefills 4
#
# [--enforce-eager 추가 이유]
#   본 워크로드는 출력 1토큰(yes/no) + 이미지 prefill 병목 → decode 거의 없음 →
#   CUDA graph 효과가 미미한 반면, graph capture 비용이 cold start의 대부분을 차지.
#   sweep 처럼 여러 모델을 갈아끼우는 환경에선 모델당 5~15분 절약됨.
#   throughput 손실은 측정상 거의 없음(rps 는 이미 compute-bound 로 포화).
#   production 챗봇 같이 긴 텍스트 생성을 다중 동시 서빙하면 다시 제거 권장.
EXTRA_VLLM_ARGS=--mm-processor-cache-gb 0 --performance-mode throughput --enforce-eager


# ============================================================================
# [8] 네트워킹 / GPU / 캐시
# ============================================================================
# 호스트 매핑 포트 (호스트에서 http://localhost:${VLLM_PORT} 로 접근).
VLLM_PORT=8000
# 컨테이너에 노출할 GPU index (콤마 구분 다중 가능, 예: 0,1).
NVIDIA_VISIBLE_DEVICES=0
# compose가 예약할 GPU 수 (위 값 개수와 일치 권장).
GPU_COUNT=1
# 모델 캐시 호스트 경로 (재기동 시 재다운로드 방지).
HF_CACHE_DIR=~/.cache/huggingface

# --- 번역(describe 한국어 번역)용 외부 API ---
# Google Gemini API 키. describe_eval 의 번역 단계에서 vLLM 자기번역 대신 사용.
# https://aistudio.google.com/apikey 에서 발급. 실제 키는 .env 에만 넣는다(gitignore).
GEMINI_API_KEY=
# 번역에 쓸 Gemini 모델.
GEMINI_TRANSLATE_MODEL=gemini-2.5-flash
